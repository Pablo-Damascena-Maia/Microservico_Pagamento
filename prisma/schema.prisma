generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Payment {
  id             Int      @id @default(autoincrement())
  orderId        Int
  userId         Int
  amount         Float
  status         String
  paymentMethod  String
  createdAt      DateTime @default(now())
}